{
  // This configuration is used for standalone TypeScript scripts in the /scripts directory
  // It compiles to CommonJS to avoid ESM/CommonJS compatibility issues with ts-node
  // while the main Next.js app uses ESM. This prevents "Cannot use import statement outside a module" errors.
  // Reference: https://github.com/TypeStrong/ts-node/issues/1007
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017"],
    "module": "commonjs",  // Critical: Compile to CommonJS for Node.js script compatibility
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "ts-node": {
    "transpileOnly": true  // Skip type checking for faster execution
  }
}